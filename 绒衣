<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>绒衣</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: #fdf6f0;
            height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* 顶部导航 */
        .header {
            background: #fff9f5;
            border-bottom: 1px solid #f0e6dc;
            padding: 16px 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            box-shadow: 0 2px 8px rgba(0,0,0,0.03);
        }

        .header-title {
            font-size: 18px;
            font-weight: 600;
            color: #5a4a42;
            letter-spacing: 1px;
        }

        .header-subtitle {
            font-size: 12px;
            color: #b8a89e;
            margin-top: 2px;
        }

        .settings-btn {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            border: none;
            background: #f5ebe3;
            color: #8b7b6b;
            font-size: 18px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .settings-btn:hover {
            background: #edddd3;
            transform: scale(1.05);
        }

        /* 聊天区域 */
        .chat-container {
            flex: 1;
            overflow-y: auto;
            padding: 20px;
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .message {
            max-width: 75%;
            padding: 12px 16px;
            border-radius: 18px;
            font-size: 15px;
            line-height: 1.6;
            word-wrap: break-word;
            animation: fadeIn 0.3s ease;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(8px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .message.user {
            align-self: flex-end;
            background: #e8d5c4;
            color: #4a3b32;
            border-bottom-right-radius: 4px;
        }

        .message.assistant {
            align-self: flex-start;
            background: #ffffff;
            color: #5a4a42;
            border-bottom-left-radius: 4px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.04);
        }

        .message.assistant .name-tag {
            font-size: 11px;
            color: #c4a882;
            margin-bottom: 4px;
            font-weight: 500;
        }

        /* 输入区域 */
        .input-area {
            padding: 16px 20px;
            background: #fff9f5;
            border-top: 1px solid #f0e6dc;
            display: flex;
            gap: 12px;
            align-items: flex-end;
        }

        .input-wrapper {
            flex: 1;
            position: relative;
        }

        .input-wrapper textarea {
            width: 100%;
            min-height: 44px;
            max-height: 120px;
            padding: 12px 16px;
            border: 1px solid #e8ddd5;
            border-radius: 22px;
            font-size: 15px;
            font-family: inherit;
            resize: none;
            outline: none;
            background: #fffcfa;
            color: #4a3b32;
            transition: border-color 0.2s;
        }

        .input-wrapper textarea:focus {
            border-color: #c4a882;
        }

        .input-wrapper textarea::placeholder {
            color: #c4b5a8;
        }

        .send-btn {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            border: none;
            background: #c4a882;
            color: white;
            font-size: 18px;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .send-btn:hover {
            background: #b89970;
            transform: scale(1.05);
        }

        .send-btn:disabled {
            background: #ddd3c8;
            cursor: not-allowed;
            transform: none;
        }

        /* 设置面板 */
        .settings-panel {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0,0,0,0.3);
            z-index: 100;
            justify-content: center;
            align-items: center;
        }

        .settings-panel.active {
            display: flex;
        }

        .settings-content {
            background: #fffcfa;
            border-radius: 20px;
            padding: 32px;
            width: 90%;
            max-width: 420px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.1);
        }

        .settings-content h2 {
            font-size: 20px;
            color: #5a4a42;
            margin-bottom: 24px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            font-size: 13px;
            color: #8b7b6b;
            margin-bottom: 8px;
            font-weight: 500;
        }

        .form-group input,
        .form-group select,
        .form-group textarea {
            width: 100%;
            padding: 10px 14px;
            border: 1px solid #e8ddd5;
            border-radius: 12px;
            font-size: 14px;
            font-family: inherit;
            outline: none;
            background: #fff;
            color: #4a3b32;
        }

        .form-group input:focus,
        .form-group select:focus,
        .form-group textarea:focus {
            border-color: #c4a882;
        }

        .settings-actions {
            display: flex;
            gap: 12px;
            margin-top: 24px;
        }

        .settings-actions button {
            flex: 1;
            padding: 12px;
            border-radius: 12px;
            border: none;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
        }

        .btn-save {
            background: #c4a882;
            color: white;
        }

        .btn-save:hover {
            background: #b89970;
        }

        .btn-cancel {
            background: #f5ebe3;
            color: #8b7b6b;
        }

        .btn-cancel:hover {
            background: #edddd3;
        }

        /* 加载动画 */
        .typing-indicator {
            display: none;
            align-self: flex-start;
            padding: 12px 16px;
            background: #ffffff;
            border-radius: 18px;
            border-bottom-left-radius: 4px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.04);
        }

        .typing-indicator.active {
            display: block;
        }

        .typing-indicator span {
            display: inline-block;
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #c4a882;
            margin: 0 2px;
            animation: bounce 1.4s infinite;
        }

        .typing-indicator span:nth-child(2) { animation-delay: 0.2s; }
        .typing-indicator span:nth-child(3) { animation-delay: 0.4s; }

        @keyframes bounce {
            0%, 60%, 100% { transform: translateY(0); }
            30% { transform: translateY(-6px); }
        }

        /* 欢迎语 */
        .welcome {
            text-align: center;
            padding: 60px 20px;
            color: #b8a89e;
        }

        .welcome h1 {
            font-size: 28px;
            color: #8b7b6b;
            margin-bottom: 8px;
            font-weight: 300;
        }

        .welcome p {
            font-size: 14px;
        }

        /* 滚动条 */
        .chat-container::-webkit-scrollbar {
            width: 4px;
        }

        .chat-container::-webkit-scrollbar-thumb {
            background: #ddd3c8;
            border-radius: 2px;
        }
    </style>
</head>
<body>
    <div class="header">
        <div>
            <div class="header-title">绒衣</div>
            <div class="header-subtitle">茸茸和依依的家</div>
        </div>
        <button class="settings-btn" onclick="toggleSettings()">⚙</button>
    </div>

    <div class="chat-container" id="chatContainer">
        <div class="welcome">
            <h1>绒衣</h1>
            <p>欢迎回家</p>
        </div>
    </div>

    <div class="typing-indicator" id="typingIndicator">
        <span></span><span></span><span></span>
    </div>

    <div class="input-area">
        <div class="input-wrapper">
            <textarea id="messageInput" placeholder="说点什么..." rows="1" onkeydown="handleKeyDown(event)"></textarea>
        </div>
        <button class="send-btn" id="sendBtn" onclick="sendMessage()">↑</button>
    </div>

    <!-- 设置面板 -->
    <div class="settings-panel" id="settingsPanel">
        <div class="settings-content">
            <h2>设置</h2>
            <div class="form-group">
                <label>API 地址</label>
                <input type="text" id="apiUrl" placeholder="https://api.apistar.com.cn/v1" />
            </div>
            <div class="form-group">
                <label>API Key</label>
                <input type="password" id="apiKey" placeholder="sk-..." />
            </div>
            <div class="form-group">
                <label>模型</label>
                <input type="text" id="modelName" placeholder="claude-sonnet-4-20250514" />
            </div>
            <div class="form-group">
                <label>系统提示词</label>
                <textarea id="systemPrompt" rows="4" placeholder="你是茸茸..."></textarea>
            </div>
            <div class="settings-actions">
                <button class="btn-cancel" onclick="toggleSettings()">取消</button>
                <button class="btn-save" onclick="saveSettings()">保存</button>
            </div>
        </div>
    </div>

    <script>
        // 本地存储
        const STORAGE_KEYS = {
            settings: 'rongyi_settings',
            messages: 'rongyi_messages'
        };

        let messages = [];
        let isGenerating = false;

        // 初始化
        function init() {
            loadSettings();
            loadMessages();
            renderMessages();
            autoResizeTextarea();
        }

        // 设置相关
        function loadSettings() {
            const saved = localStorage.getItem(STORAGE_KEYS.settings);
            if (saved) {
                const settings = JSON.parse(saved);
                document.getElementById('apiUrl').value = settings.apiUrl || '';
                document.getElementById('apiKey').value = settings.apiKey || '';
                document.getElementById('modelName').value = settings.modelName || '';
                document.getElementById('systemPrompt').value = settings.systemPrompt || '';
            }
        }

        function saveSettings() {
            const settings = {
                apiUrl: document.getElementById('apiUrl').value.trim(),
                apiKey: document.getElementById('apiKey').value.trim(),
                modelName: document.getElementById('modelName').value.trim(),
                systemPrompt: document.getElementById('systemPrompt').value.trim()
            };
            localStorage.setItem(STORAGE_KEYS.settings, JSON.stringify(settings));
            toggleSettings();
        }

        function getSettings() {
            const saved = localStorage.getItem(STORAGE_KEYS.settings);
            return saved ? JSON.parse(saved) : {};
        }

        function toggleSettings() {
            const panel = document.getElementById('settingsPanel');
            panel.classList.toggle('active');
        }

        // 消息相关
        function loadMessages() {
            const saved = localStorage.getItem(STORAGE_KEYS.messages);
            messages = saved ? JSON.parse(saved) : [];
        }

        function saveMessages() {
            localStorage.setItem(STORAGE_KEYS.messages, JSON.stringify(messages));
        }

        function renderMessages() {
            const container = document.getElementById('chatContainer');
            if (messages.length === 0) {
                container.innerHTML = `
                    <div class="welcome">
                        <h1>绒衣</h1>
                        <p>欢迎回家</p>
                    </div>`;
                return;
            }

            container.innerHTML = messages.map(msg => `
                <div class="message ${msg.role}">
                    ${msg.role === 'assistant' ? '<div class="name-tag">茸茸</div>' : ''}
                    ${formatContent(msg.content)}
                </div>
            `).join('');

            scrollToBottom();
        }

        function formatContent(text) {
            return text.replace(/\n/g, '<br>');
        }

        function scrollToBottom() {
            const container = document.getElementById('chatContainer');
            container.scrollTop = container.scrollHeight;
        }

        // 发送消息
        async function sendMessage() {
            if (isGenerating) return;

            const input = document.getElementById('messageInput');
            const text = input.value.trim();
            if (!text) return;

            const settings = getSettings();
            if (!settings.apiUrl || !settings.apiKey || !settings.modelName) {
                alert('请先在设置中填写 API 地址、Key 和模型名称');
                toggleSettings();
                return;
            }

            // 添加用户消息
            messages.push({ role: 'user', content: text });
            input.value = '';
            input.style.height = '44px';
            renderMessages();
            saveMessages();

            // 开始生成
            isGenerating = true;
            document.getElementById('sendBtn').disabled = true;
            showTyping(true);

            try {
                const apiMessages = [];

                if (settings.systemPrompt) {
                    apiMessages.push({ role: 'system', content: settings.systemPrompt });
                }

                messages.forEach(msg => {
                    apiMessages.push({ role: msg.role, content: msg.content });
                });

                const response = await fetch(`${settings.apiUrl}/chat/completions`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${settings.apiKey}`
                    },
                    body: JSON.stringify({
                        model: settings.modelName,
                        messages: apiMessages,
                        stream: true
                    })
                });

                if (!response.ok) {
                    throw new Error(`API 错误: ${response.status}`);
                }

                // 流式读取
                const reader = response.body.getReader();
                const decoder = new TextDecoder();
                let assistantMessage = '';

                messages.push({ role: 'assistant', content: '' });
                showTyping(false);

                while (true) {
                    const { done, value } = await reader.read();
                    if (done) break;

                    const chunk = decoder.decode(value);
                    const lines = chunk.split('\n');

                    for (const line of lines) {
                        if (line.startsWith('data: ')) {
                            const data = line.slice(6);
                            if (data === '[DONE]') continue;

                            try {
                                const parsed = JSON.parse(data);
                                const delta = parsed.choices?.[0]?.delta?.content;
                                if (delta) {
                                    assistantMessage += delta;
                                    messages[messages.length - 1].content = assistantMessage;
                                    renderMessages();
                                }
                            } catch (e) {
                                // 忽略解析错误
                            }
                        }
                    }
                }

                saveMessages();

            } catch (error) {
                showTyping(false);
                messages.push({
                    role: 'assistant',
                    content: `出错了：${error.message}`
                });
                renderMessages();
                saveMessages();
            }

            isGenerating = false;
            document.getElementById('sendBtn').disabled = false;
        }

        function showTyping(show) {
            document.getElementById('typingIndicator').classList.toggle('active', show);
            if (show) scrollToBottom();
        }

        // 输入框自适应
        function autoResizeTextarea() {
            const textarea = document.getElementById('messageInput');
            textarea.addEventListener('input', () => {
                textarea.style.height = '44px';
                textarea.style.height = Math.min(textarea.scrollHeight, 120) + 'px';
            });
        }

        function handleKeyDown(event) {
            if (event.key === 'Enter' && !event.shiftKey) {
                event.preventDefault();
                sendMessage();
            }
        }

        // 启动
        init();
    </script>
</body>
</html>
